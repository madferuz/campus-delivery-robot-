<?xml version="1.0"?>
<!--
  test_delivery_box_service.test
  ==============================
  Boots Member 6's delivery_box_service_node and runs the integration
  test module against it.
-->
<launch>
  <node pkg="delivery_mission"
        type="delivery_box_service_node.py"
        name="delivery_box_service_node"
        output="screen">
    <param name="actuation_time_s" value="0.3"/>
  </node>

  <test test-name="delivery_box_service"
        pkg="delivery_tests"
        type="test_delivery_box_service.py"
        time-limit="60.0"
        args="--with-ros"/>
</launch>
